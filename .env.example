# APP_URL: The URL where this applet is hosted.
# This value is typically provided by your deployment environment or set locally.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# BACKEND_URL: The URL for the backend API used by the frontend node server.
# Set to your local backend during development, or to your deployed backend URL.
BACKEND_URL="http://localhost:8081"

# VITE_API_BASE: The URL for the backend API used directly by the frontend static bundle.
# Useful when deploying statically (e.g., to Cloudflare Pages). Leave empty to use relative paths (proxy).
VITE_API_BASE="http://localhost:8080"

